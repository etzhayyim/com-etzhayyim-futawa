;; futawa 二輪 — moto_provenance_binder cell (langgraph, WASM runtime)
;; ADR-2605261330 · L5c terminal provenance binder + Council attestation
{:cell/id "moto_provenance_binder"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_provenance_binder"
 :cell/doc "L5c terminal provenance binder: merges all L1-L5b attestations into final production record; Council 5-of-7 Safe attestation gate (silenMobilityReview). Binds testRecord PASS lot into immutable provenance log. Input: all previous attestations + testRecord PASS confirmation. Output: silenMobilityReview (Council-signed final provenance chain)."
 :cell/state-graph
 {:nodes [:collect-attestations :verify-test-pass :construct-provenance-chain :gate-council-review :bind-provenance]
  :entry :collect-attestations
  :edges [[:collect-attestations :verify-test-pass] [:verify-test-pass :construct-provenance-chain]
          [:construct-provenance-chain :gate-council-review] [:gate-council-review :bind-provenance] [:bind-provenance :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3"]
 :cell/invokes
 [{:actor "council" :fn "attestSilenMobilityReview" :purpose "Council 5-of-7 Safe final production gate"}]
 :cell/kotoba
 {:reads [:frame-attestation/id :engine-attestation/id :drivetrain-attestation/id :suspension-brake-attestation/id :electrical-attestation/id :paint-attestation/id :vehicle-lot-attestation/id :test-record/id]
  :writes [:silen-mobility-review/id :silen-mobility-review/provenance-chain-cid :silen-mobility-review/council-sig]}}
