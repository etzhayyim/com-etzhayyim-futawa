;; futawa 二輪 — moto_body_paint cell (langgraph, WASM runtime)
;; ADR-2605261330 · L4 body panels + paint + G5 Charter artwork scan
{:cell/id "moto_body_paint"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_body_paint"
 :cell/doc "L4 body panels (ABS or composite) + paint + artwork. G5 Charter §2(a-h) scan on every design/artwork. Suri paint-sprayer (R1+ robot) applies electrostatic + HVLP with G5 artwork integrated. Input: body-panel-mold, paint-spec (VOC ≤ limits), artwork-design (scanned). Output: paintAttestation (paint-batch + VOC-test + G5 scanned)."
 :cell/state-graph
 {:nodes [:validate-body-panels :scan-artwork-charter :prepare-paint :apply-paint :cure-paint :attest-paint]
  :entry :validate-body-panels
  :edges [[:validate-body-panels :scan-artwork-charter] [:scan-artwork-charter :prepare-paint]
          [:prepare-paint :apply-paint] [:apply-paint :cure-paint] [:cure-paint :attest-paint] [:attest-paint :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G4" "G5"]
 :cell/kotoba
 {:reads [:body-panel-mold/type :paint-spec/voc-limit :artwork-design/cid]
  :writes [:paint-attestation/id :paint-attestation/paint-batch :paint-attestation/voc-test-result :paint-attestation/g5-charter-scan-pass]}}
