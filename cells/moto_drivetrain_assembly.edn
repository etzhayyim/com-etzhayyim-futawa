;; futawa 二輪 — moto_drivetrain_assembly cell (langgraph, WASM runtime)
;; ADR-2605261330 · L2b drivetrain assembly (transmission + clutch + chain/belt)
{:cell/id "moto_drivetrain_assembly"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_drivetrain_assembly"
 :cell/doc "L2b drivetrain assembly: transmission (manual/DCT), clutch, chain/belt, sprocket-set. Validates gear ratios for performance + durability (30-year G14). Input: transmission-box, clutch-plate, chain/belt-spec, sprockets. Output: drivetrainAttestation (ratio-table + wear-resistance)."
 :cell/state-graph
 {:nodes [:validate-transmission :prepare-clutch :install-chain-belt :measure-ratio :attest-drivetrain]
  :entry :validate-transmission
  :edges [[:validate-transmission :prepare-clutch] [:prepare-clutch :install-chain-belt]
          [:install-chain-belt :measure-ratio] [:measure-ratio :attest-drivetrain] [:attest-drivetrain :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3" "G14"]
 :cell/kotoba
 {:reads [:transmission-box/type :clutch-plate/material :chain-belt/spec :sprocket-set/ratios]
  :writes [:drivetrain-attestation/id :drivetrain-attestation/final-ratio :drivetrain-attestation/wear-resistance]}}
