;; futawa 二輪 — moto_engine_assembly cell (langgraph, WASM runtime)
;; ADR-2605261330 · L2a engine/motor assembly + torque + ≤250cc/≤15kW cap check
{:cell/id "moto_engine_assembly"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_engine_assembly"
 :cell/doc "L2a engine/motor assembly + torque attestation + G11 capacity cap (≤250cc / ≤15kW) enforced. Input: engine-block (cast or forged), piston-rod-crank lot, valvetrain, ignition, fuel. Output: engineAttestation (displacement + power + torque + G11 certified)."
 :cell/state-graph
 {:nodes [:validate-engine-block :prepare-piston-assembly :install-valvetrain :check-displacement :attest-engine]
  :entry :validate-engine-block
  :edges [[:validate-engine-block :prepare-piston-assembly] [:prepare-piston-assembly :install-valvetrain]
          [:install-valvetrain :check-displacement] [:check-displacement :attest-engine] [:attest-engine :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G11"]
 :cell/kotoba
 {:reads [:engine-block/lot :piston-rod-crank/lot :valvetrain/spec :fuel-spec/type]
  :writes [:engine-attestation/id :engine-attestation/displacement-cc :engine-attestation/power-kw :engine-attestation/torque-nm]}}
