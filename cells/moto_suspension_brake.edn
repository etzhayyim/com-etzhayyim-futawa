;; futawa 二輪 — moto_suspension_brake cell (langgraph, WASM runtime)
;; ADR-2605261330 · L3b suspension + brake + G7 ABS-mandatory validation
{:cell/id "moto_suspension_brake"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_suspension_brake"
 :cell/doc "L3b suspension + brake assembly + G7 ABS-mandatory enforcement (≥125cc / ≥6kW electric; NO ABS-delete). Validates suspension stiffness (30-year design life per G14), brake torque, ABS ECU calibration. Input: fork/monoshock-spec, brake-fluid-spec, ABS-ECU-calibration. Output: suspensionBrakeAttestation (stiffness-ratings + ABS-mandatory-certified)."
 :cell/state-graph
 {:nodes [:validate-suspension :prepare-brake-fluid :validate-abs-ecu :check-abs-mandatory :attest-suspension-brake]
  :entry :validate-suspension
  :edges [[:validate-suspension :prepare-brake-fluid] [:prepare-brake-fluid :validate-abs-ecu]
          [:validate-abs-ecu :check-abs-mandatory] [:check-abs-mandatory :attest-suspension-brake] [:attest-suspension-brake :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G7" "G14"]
 :cell/kotoba
 {:reads [:fork-monoshock/spec :brake-fluid/iso-class :abs-ecu/calibration-cid :engine-attestation/power-kw]
  :writes [:suspension-brake-attestation/id :suspension-brake-attestation/stiffness-rating :suspension-brake-attestation/abs-mandatory-certified]}}
