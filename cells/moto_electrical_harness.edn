;; futawa 二輪 — moto_electrical_harness cell (langgraph, WASM runtime)
;; ADR-2605261330 · L3a electrical harness + ECU + G8 NO surveillance manifest
{:cell/id "moto_electrical_harness"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_electrical_harness"
 :cell/doc "L3a electrical harness routing + ECU firmware + G8 NO-surveillance manifest (NO GPS / NO telematics / NO connected-app / NO V2X / NO proprietary diagnostic-DRM). Safety ECU (ABS for G7, fuel injection) open-source. Input: harness-design (CAD), ECU-firmware (open-source), diagnostic-protocol (open). Output: electricalAttestation (routing-diagram + G8 no-surveillance certified)."
 :cell/state-graph
 {:nodes [:validate-harness-design :validate-ecu-firmware :scan-surveillance-prohibitions :route-harness :attest-electrical]
  :entry :validate-harness-design
  :edges [[:validate-harness-design :validate-ecu-firmware] [:validate-ecu-firmware :scan-surveillance-prohibitions]
          [:scan-surveillance-prohibitions :route-harness] [:route-harness :attest-electrical] [:attest-electrical :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G8"]
 :cell/kotoba
 {:reads [:harness-design/cad-cid :ecu-firmware/source-repo :diagnostic-protocol/spec]
  :writes [:electrical-attestation/id :electrical-attestation/harness-cid :electrical-attestation/ecu-firmware-hash :electrical-attestation/g8-surveillance-clear]}}
