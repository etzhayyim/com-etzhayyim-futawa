;; futawa 二輪 — moto_frame_welding cell (langgraph, WASM runtime)
;; ADR-2605261330 · L1 frame welding, roundness, material lot attestation
{:cell/id "moto_frame_welding"
 :cell/glyph "二"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_frame_welding"
 :cell/doc "L1 frame weld + roundness + material lot. TIG/MIG vision-guided weld (Tsugite R1+ robot). Input: tube-stock lot (steel/aluminum spec), weld-spec. Output: frameAttestation (weld-quality + roundness + mass)."
 :cell/state-graph
 {:nodes [:validate-tube-stock :prepare-weld-fixture :execute-weld :measure-roundness :attest-frame]
  :entry :validate-tube-stock
  :edges [[:validate-tube-stock :prepare-weld-fixture] [:prepare-weld-fixture :execute-weld]
          [:execute-weld :measure-roundness] [:measure-roundness :attest-frame] [:attest-frame :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G2" "G3"]
 :cell/kotoba
 {:reads [:material-lot/id :material-lot/grade :weld-spec/type]
  :writes [:frame-attestation/id :frame-attestation/material-lot :frame-attestation/weld-quality :frame-attestation/roundness-um]}}
