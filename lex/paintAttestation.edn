;; com.etzhayyim.futawa.paintAttestation — lexicon (EDN form)
;; L4 body panels + paint + G5 Charter artwork scan + VOC
{:lexicon 1
 :id "com.etzhayyim.futawa.paintAttestation"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["paintAttestationId" "paintBatch" "vocTestResult"]
    :properties
    {:paintAttestationId    {:type "string"}
     :paintBatch            {:type "string" :description "paint lot + supplier cert"}
     :vocTestResult         {:type "string" :description "VOC emission test result (≤limit)"}
     :artworkDesignCid      {:type "string" :description "artwork design IPFS CID (Charter-scanned)"}
     :g5CharterScanPass     {:type "boolean" :description "Charter §2(a-h) scan passed (no prohibited content)"}
     :bodyPanelMoldType     {:type "string" :description "ABS / composite / carbon-fiber"}
     :cureDatetime          {:type "string" :description "paint cure completion datetime"}
     :timestamp             {:type "string" :description "ISO-8601 timestamp"}}}}}}
