;; futawa 二輪 — kotoba EAVT schema
;; ADR-2605261330 · motorcycle manufacturing over kotoba Datoms
;; L1-L5 assembly attestations (frame / engine / drivetrain / electrical / suspension / body / assembly / test / provenance)

[;; ───────────────────────────── :material-lot/* — raw material supply ─────────────────────────────
 {:db/ident :material-lot/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "material batch ID (steel / aluminum tube stock, engine block cast, etc.)"}
 {:db/ident :material-lot/grade
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "material grade (e.g. ASTM A513 chromoly, 6061-T6 aluminum)"}
 {:db/ident :material-lot/supplier-did
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one}

 ;; ───────────────────────────── :frame-attestation/* — L1 output ─────────────────────────────
 {:db/ident :frame-attestation/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity}
 {:db/ident :frame-attestation/material-lot
  :db/valueType :db.type/ref
  :db/cardinality :db.cardinality/one}
 {:db/ident :frame-attestation/weld-quality
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "TIG/MIG vision-guided signature"}
 {:db/ident :frame-attestation/roundness-um
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "roundness tolerance (micrometers); robot witness"}
 {:db/ident :frame-attestation/mass-kg
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one}
 {:db/ident :frame-attestation/draft-frame-cid
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "IPFS CAD CID"}

 ;; ───────────────────────────── :engine-attestation/* — L2a output ─────────────────────────────
 {:db/ident :engine-attestation/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity}
 {:db/ident :engine-attestation/displacement-cc
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
