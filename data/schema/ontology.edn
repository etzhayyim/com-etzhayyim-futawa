  :db/cardinality :db.cardinality/one}
 {:db/ident :engine-attestation/g11-cap-verified
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one}

 ;; ───────────────────────────── :drivetrain-attestation/* — L2b output ─────────────────────────────
 {:db/ident :drivetrain-attestation/id
